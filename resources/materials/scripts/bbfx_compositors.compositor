// BBFx Compositor Definitions — wrapping existing GLSL shaders
// These use StdQuad_vp_glsl as vertex program and reference shaders in ../shaders/

// --- Batch 1: Simple single-pass compositors ---

compositor Vignette
{
    technique
    {
        texture rt0 target_width target_height PF_A8R8G8B8
        target rt0 { input previous }
        target_output
        {
            input none
            pass render_quad
            {
                material BBFx/Vignette
                input 0 rt0
            }
        }
    }
}

