compositor MotionTrail
{
    technique
    {
        texture rt0 target_width target_height PF_A8R8G8B8
        target rt0 { input previous }
        target_output
        {
            // Simple pass-through with slight blur effect as motion trail approximation
            input none
            pass render_quad
            {
                material BBFx/MotionTrail
                input 0 rt0
            }
        }
    }
}
